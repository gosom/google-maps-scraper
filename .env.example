# BrezelScraper Backend — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env or any .env.* (except this file) to version control.
#
# This file is the canonical manifest of every environment variable the
# binary reads. It is enforced by TestEnvExampleParity in pkg/config.

# ─────────────────────────────────────────────────────────────────────
# CORE / RUNTIME
# ─────────────────────────────────────────────────────────────────────

# Runtime environment. Accepted: development (default), staging, production.
APP_ENV=development

# Number of concurrent scraping workers (0 = auto).
CONCURRENCY=2

# Folder where job CSV files are stored.
DATA_FOLDER=./webdata

# Disable anonymous telemetry (false = enabled).
DISABLE_TELEMETRY=false

# Address the internal metrics/health HTTP server listens on.
INTERNAL_ADDR=:9090

# Log level: debug | info | warn | error.
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────
# AUTH & CRYPTO
# ─────────────────────────────────────────────────────────────────────

# HMAC secret used to derive API key lookup hashes. Must be at least 32 bytes.
# Generate with: openssl rand -hex 32
API_KEY_SERVER_SECRET=REPLACE_WITH_64_HEX_CHARS

# Clerk authentication secret key (required).
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_CLERK_SECRET_KEY

# Clerk webhook signing secret (Svix-format, whsec_*). When set, mounts the
# /webhooks/clerk endpoint that eagerly provisions users on user.created
# events from the Clerk Dashboard webhook configuration. When empty (the
# default in dev/test), the route is not mounted and the auth middleware's
# lazy-provisioning fallback handles signups instead. Per-environment —
# Clerk test and prod instances have independent signing secrets.
CLERK_WEBHOOK_SIGNING_SECRET=

# AES-256 encryption key — must be exactly 32 bytes in production.
# Generate with: openssl rand -hex 16 | head -c 32
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────
# AWS / S3
# ─────────────────────────────────────────────────────────────────────

# AWS credentials for S3 CSV upload (optional).
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY
AWS_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_KEY

# AWS_ENDPOINT — leave empty for AWS S3.
# For DigitalOcean Spaces, set the regional host:
#   AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_ENDPOINT=
AWS_FORCE_PATH_STYLE=false      # true only if you need path-style URLs (e.g. bucket name contains dots)
AWS_SSE_ENABLED=false           # true on AWS for SSE-S3; default off for DO Spaces (which auto-encrypts at rest)
AWS_CHECKSUM_MODE=              # empty (default) or "required" — set "required" only if S3-compat backend rejects CRC32 trailers

# S3 bucket for exported CSV files.
S3_BUCKET_NAME=REPLACE_WITH_BUCKET_NAME

# ─────────────────────────────────────────────────────────────────────
# BUILD METADATA (injected at build time via -ldflags)
# ─────────────────────────────────────────────────────────────────────

BUILD_DATE=
ENVIRONMENT=development
GIT_COMMIT=
VERSION=

# ─────────────────────────────────────────────────────────────────────
# CLI BOOTSTRAP
# ─────────────────────────────────────────────────────────────────────

# Set to "1" to install Playwright browsers and exit immediately.
# Checked before normal startup — intentionally outside pkg/config.Config.
PLAYWRIGHT_INSTALL_ONLY=0

# ─────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (required in production).
ALLOWED_ORIGINS=https://brezel.ai,https://www.brezel.ai,https://staging.brezel.ai

# ─────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required).
DSN=postgres://scraper:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/google_maps_scraper?sslmode=disable

# Optional separate DSN for running migrations (falls back to DSN if unset).
MIGRATION_DSN=

# ─────────────────────────────────────────────────────────────────────
# DATABASE CONNECTION POOL
# ─────────────────────────────────────────────────────────────────────

# Max connection idle time before recycling (e.g. "2m", "30s").
DB_CONN_MAX_IDLE_TIME=2m

# Max connection lifetime before recycling (e.g. "5m", "30s").
DB_CONN_MAX_LIFETIME=5m

# Max idle connections kept in pool.
DB_MAX_IDLE_CONNS=10

# Max simultaneous open connections.
DB_MAX_OPEN_CONNS=25

# ─────────────────────────────────────────────────────────────────────
# EXTERNAL SERVICES
# ─────────────────────────────────────────────────────────────────────

# Proxies — provider-agnostic, comma-separated list of proxy URLs.
# Format per entry: http://USERNAME:PASSWORD@HOST:PORT
# Works with any rotating-gateway provider (Decodo, Bright Data, Smartproxy, etc.).
# Decodo example (single rotating gateway):
#   PROXIES=http://USERNAME:PASSWORD@gate.decodo.com:10001
# Multiple entries:
#   PROXIES=http://u:p@host1:1,http://u:p@host2:2
PROXIES=

# Resend API key for transactional email.
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY

# Legacy: Webshare API key. Leave empty unless you specifically use Webshare's
# IP-authorization + proxy-list API. Most providers (incl. Decodo) only need
# PROXIES above.
WEBSHARE_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# GOOGLE AUTH
# ─────────────────────────────────────────────────────────────────────

# Google OAuth credentials (optional — for Sheets integration).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_COOKIES_FILE=/path/to/google_cookies.json
GOOGLE_REDIRECT_URL=

# ─────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────

# Log directory (relative or absolute path).
LOG_DIR=logs

# Log file name within LOG_DIR.
LOG_FILE_NAME=brezel-api.log

# Absolute path to log file; overrides LOG_DIR + LOG_FILE_NAME when set.
LOG_FILE_PATH=

# Maximum log file size in megabytes before rotation.
LOG_MAX_SIZE_MB=100

# Log output destination: stdout | file | both.
LOG_OUTPUT=both

# Number of days to retain rotated log files.
LOG_RETENTION_DAYS=7

# ─────────────────────────────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────────────────────────────

# Stripe API secret key (required in production).
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY

# Comma-separated list of CIDR ranges allowed to deliver webhook events.
STRIPE_WEBHOOK_ALLOWED_CIDRS=

# Current Stripe webhook signing secret (required in production).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SIGNING_SECRET

# Previous webhook signing secret — used during key rotation.
STRIPE_WEBHOOK_SECRET_PREVIOUS=

# ─────────────────────────────────────────────────────────────────────
# STUCK-JOB DETECTION
# ─────────────────────────────────────────────────────────────────────

# How often (minutes) the stuck-job reaper runs.
STUCK_JOB_CHECK_INTERVAL_MINUTES=10

# Jobs not updated for this many hours are auto-failed.
STUCK_JOB_TIMEOUT_HOURS=4

# ─────────────────────────────────────────────────────────────────────
# WEBHOOK EVENT CLEANUP
# ─────────────────────────────────────────────────────────────────────

# Days to retain processed_webhook_events rows (Stripe retry window is 3 days).
WEBHOOK_EVENT_RETENTION_DAYS=90

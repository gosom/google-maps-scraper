# BrezelScraper Backend — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env or any .env.* (except this file) to version control.

# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────

# PostgreSQL connection string (required for web/database mode)
DSN=postgres://scraper:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/google_maps_scraper?sslmode=disable

# Clerk authentication secret key (required)
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_CLERK_SECRET_KEY

# Stripe payment keys (required when billing is enabled)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SIGNING_SECRET

# ─────────────────────────────────────────────
# SERVER (optional — safe defaults shown)
# ─────────────────────────────────────────────

# Address the HTTP server listens on
WEB_ADDR=:8080

# Folder where job CSV files are stored
DATA_FOLDER=./webdata

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Number of concurrent scraping workers
CONCURRENCY=2

# Disable anonymous telemetry (0 = enabled, 1 = disabled)
DISABLE_TELEMETRY=0

# ─────────────────────────────────────────────
# CORS (required in production)
# ─────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (no wildcard in production)
ALLOWED_ORIGINS=https://brezel.ai,https://www.brezel.ai,https://staging.brezel.ai

# ─────────────────────────────────────────────
# DATABASE CONNECTION POOL (optional)
# ─────────────────────────────────────────────

# Max simultaneous open connections. Must be >= 1. Setting to 0 = unbounded pool (not allowed in production).
DB_MAX_OPEN_CONNS=25

# Max idle connections kept in pool
DB_MAX_IDLE_CONNS=10

# Max connection lifetime before recycling (e.g. "5m", "30s")
DB_CONN_MAX_LIFETIME=5m

# ─────────────────────────────────────────────
# STUCK-JOB DETECTION (optional)
# ─────────────────────────────────────────────

# How often (minutes) the stuck-job reaper runs
STUCK_JOB_CHECK_INTERVAL_MINUTES=10

# Jobs not updated for this many hours are auto-failed
STUCK_JOB_TIMEOUT_HOURS=4

# ─────────────────────────────────────────────
# WEBHOOK EVENT CLEANUP (optional)
# ─────────────────────────────────────────────

# Days to retain processed_webhook_events rows (Stripe retries window is 3 days)
WEBHOOK_EVENT_RETENTION_DAYS=90

# ─────────────────────────────────────────────
# STRIPE REDIRECT URLS (optional)
# ─────────────────────────────────────────────

# These are used by the billing service for Stripe Checkout redirect
STRIPE_SUCCESS_URL=https://brezel.ai/dashboard/credits?success=1
STRIPE_CANCEL_URL=https://brezel.ai/dashboard/credits?cancelled=1

# ─────────────────────────────────────────────
# API KEY AUTHENTICATION (required — enables programmatic API access)
# ─────────────────────────────────────────────

# HMAC secret used to derive API key lookup hashes. Must be at least 32 bytes.
# The server will refuse to start if this is missing or too short.
# Generate with: openssl rand -hex 32
API_KEY_SERVER_SECRET=REPLACE_WITH_64_HEX_CHARS

# ─────────────────────────────────────────────
# AWS / S3 (optional — for CSV upload to S3)
# ─────────────────────────────────────────────

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_KEY
S3_BUCKET_NAME=REPLACE_WITH_BUCKET_NAME

# ─────────────────────────────────────────────
# PROXY (optional — Webshare rotating proxies)
# ─────────────────────────────────────────────

WEBSHARE_API_KEY=REPLACE_WITH_WEBSHARE_API_KEY

# ─────────────────────────────────────────────
# GOOGLE AUTH (optional — for Sheets integration)
# ─────────────────────────────────────────────

GOOGLE_COOKIES_FILE=/path/to/google_cookies.json

# ─────────────────────────────────────────────
# DOCKER / CI-CD (docker-compose.production.yaml)
# ─────────────────────────────────────────────

# Container image to deploy (e.g. ghcr.io/yourorg/brezel-api)
DOCKER_IMAGE=ghcr.io/yourorg/brezel-api

# Image tag — always pin in production, never use "latest"
DOCKER_IMAGE_TAG=latest

# Grafana admin password — REQUIRED in production, no default (intentional)
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD

# ─────────────────────────────────────────────
# ENVIRONMENT (required in production)
# ─────────────────────────────────────────────

# Runtime environment identifier. Set to "production" in production deployments.
# The server will refuse to start if APP_ENV=production AND BRAZA_DEV_AUTH_BYPASS=1.
APP_ENV=production

# ─────────────────────────────────────────────
# DEV-ONLY FLAGS — NEVER SET IN PRODUCTION
# ─────────────────────────────────────────────

# Enables authentication bypass for local integration tests via X-Braza-Dev-User header.
# When set to 1, any caller can impersonate any user ID using only a request header —
# NO Clerk JWT is required. This is a complete authentication bypass.
#
# SECURITY WARNING: Setting this in production gives any attacker full access to all
# accounts. The server will hard-fail at startup if BRAZA_DEV_AUTH_BYPASS=1 is
# combined with APP_ENV=production.
#
# DEV ONLY — never set in production
# BRAZA_DEV_AUTH_BYPASS=1

# DSN is injected by GitHub Actions
DSN=postgres://scraper:password@host.docker.internal:5432/google_maps_scraper?sslmode=disable

# Server Configuration
PORT=8080
HOST=0.0.0.0
ENV=staging
LOG_LEVEL=info
# CONCURRENCY is injected by GitHub Actions based on CPU cores
CONCURRENCY=
DATA_FOLDER=webdata

# Authentication is Injected by GitHub Actions
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Payment Processing is Injected by GitHub Actions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Integration is Injected by GitHub Actions
GOOGLE_CLIENT_SECRET=

# Scraper Config
# PROXIES=http://user:pass@host:port
# WEBSHARE_API_KEY=
MAX_RESULTS=100
SCRAPER_TIMEOUT=30
DISABLE_TELEMETRY=1

# --- S3 / DigitalOcean Spaces ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1            # AWS region OR DO region slug — see https://docs.digitalocean.com/products/spaces/details/availability/ for current list
# AWS_ENDPOINT — leave empty for AWS S3.
# For DigitalOcean Spaces, set the regional host:
#   AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_ENDPOINT=
AWS_FORCE_PATH_STYLE=false      # true only if you need path-style URLs (e.g. bucket name contains dots)
AWS_SSE_ENABLED=false           # true on AWS for SSE-S3; default off for DO Spaces (which auto-encrypts at rest)
AWS_CHECKSUM_MODE=              # empty (default) or "required" — set "required" only if S3-compat backend rejects CRC32 trailers
S3_BUCKET_NAME=

# Frontend URLs
FRONTEND_URL=https://staging.brezel.ai
ALLOWED_ORIGINS=https://staging.brezel.ai,http://localhost:3000

# Monitoring
GRAFANA_ADMIN_PASSWORD=

# Ops alerting — refund_deficit_applied events visible in Loki/Grafana
# Board decision: SMTP email alerting is out of scope for MVP (see BRE-52).
# Use Grafana Explore → brezel-loki datasource to view refund_deficit_applied events.
# The Grafana alert rule is present in Grafana UI (no email routing needed).

# Future: SMTP email alerting (post-MVP)
# OPS_ALERT_EMAIL=ops@brezel.ai
# GF_SMTP_ENABLED=false
# GF_SMTP_HOST=smtp.example.com:587
# GF_SMTP_USER=
# GF_SMTP_PASSWORD=

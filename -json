"Kids' menu"",""enabled"":true}]},{""id"":""parking"",""name"":""Parking"",""options"":[{""name"":""Free parking lot"",""enabled"":true},{""name"":""Free street parking"",""enabled"":true},{""name"":""Parking"",""enabled"":false}]},{""id"":""pets"",""name"":""Pets"",""options"":[{""name"":""Dogs allowed outside"",""enabled"":true}]}]","[{""Name"":""D. Turner"",""ProfilePicture"":""https://lh3.googleusercontent.com/a-/ALV-UjVjC2JZww0ld3CH6m0y-i9E0qUBLjGnH2Gw1kq66iu4dwOSDPC3=s120-c-rp-mo-ba4-br100"",""Rating"":4,""Description"":""We went around 5:30 on a Saturday. It wasn't busy; lots of open seating. We loved the artwork painted on the walls and the music. Once we were seated, no one came to take our drink orders for about 10 mins, until one of the servers stopped by and asked if we'd been helped. He was very kind and swift with our orders, even allowing my spouse to practice ordering in Spanish. We got birria tacos and the salsa verde burrito (we think; it was a limited-time item). You get unlimited chips and salsa, too, and whew that salsa was yummy.\n\nBoth were absolutely delicious! The food came out super quick, too. For dessert, we got the fried ice cream and blueberry cobbler cheesecake. Both a hit!\n\nAlthough I got a cocktail, I won't comment on it because I usually don't drink alcohol because I don't care for it, so my opinion on whether it is good or not is skewed.\n\nWould definitely go back if in the area!"",""Images"":[""https://lh3.googleusercontent.com/grass-cs/ANxoTn2PzKCb0jL1pGOwQzDGzswmhmKT_lrsnCBBruy77E1t3ScyWkQDYiiZbjD2oZl5UVJhW68H34MhT-bcNGjLaavsEd2eciSLpTrfCB9cR8GdopxaOm-chtLl-ICcT-9PBLNXTgdtrH3UUEIM=k-no"",""https://lh3.googleusercontent.com/grass-cs/ANxoTn3n6-7_VnL9XiF59f4WwYsummSk-1W8I04U7W_dusfOboOzzMyHUTVxLI37MwK7ILGFey8EbkPtz8pCOfAyH4d6I1L-lyA36RGqxRYljqYqM91VCnHvsxOq2wP-i5sMS9Cz5M-cqjrTbgOe=k-no"",""https://lh3.googleusercontent.com/grass-cs/ANxoTn2wwhESHXO5D0HX9Jvf9gRslq0DR6PAsAX7sTrvgPPc6dmvkwJKQbACOlBPCTJ-IpCumkBw81XF0R3-c-ZFE_vyQIuyi
me"":""Table service"",""enabled"":true}]},{""id"":""amenities"",""name"":""Amenities"",""options"":[{""name"":""Bar onsite"",""enabled"":true},{""name"":""Restroom"",""enabled"":true}]},{""id"":""atmosphere"",""name"":""Atmosphere"",""options"":[{""name"":""Casual"",""enabled"":true},{""name"":""Cozy"",""enabled"":true},{""name"":""Quiet"",""enabled"":true},{""name"":""Trendy"",""enabled"":true}]},{""id"":""crowd"",""name"":""Crowd"",""options"":[{""name"":""Groups"",""enabled"":true},{""name"":""Tourists"",""enabled"":true}]},{""id"":""planning"",""name"":""Planning"",""options"":[{""name"":""Accepts reservations"",""enabled"":true}]},{""id"":""payments"",""name"":""Payments"",""options"":[{""name"":""Credit cards"",""enabled"":true},{""name"":""Debit cards"",""enabled"":true},{""name"":""Credit cards"",""enabled"":false}]},{""id"":""children"",""name"":""Children"",""options"":[{""name"":""Good for kids"",""enabled"":true},{""name"":""High chairs"",""enabled"":true},{""name"":""Kids' menu"",""enabled"":true}]},{""id"":""parking"",""name"":""Parking"",""options"":[{""name"":""Free parking lot"",""enabled"":true},{""name"":""Free street parking"",""enabled"":true},{""name"":""Parking"",""enabled"":false}]}]","[{""Name"":""Gary King"",""ProfilePicture"":""https://lh3.googleusercontent.com/a/ACg8ocI7fAqtve2k2Z_MZzng2B0DzuAF49CPjTPr0wlVX4oArS8tEg=s120-c-rp-mo-ba2-br100"",""Rating"":5,""Description"":""We are from out of town and remember Azteca from last year. This year we made a point to make a return trip because we enjoyed it so much.  Today we had Ceviche to start and it was amazing. We followed up the Azteca Fajita platter and it took was delicious. Carmen served us today and did an outstanding job and kept the drinks coming. We will definitely be back.\nHighly recommended."",""Images"":[""https://lh3.googleusercontent.com/grass-cs/ANxoTn3ZaCdfj1w0DTaIuHepSM3tEm_J3mAKSggOdAfCCmesAZcyzxA2fo9td29NqK7uIudmpE_JA-MbrOp6bq6OvnFXrLLP6FSZdZSv-DFji8CP9ladoDMRWlCTLijHTnzabngcQ_6TIMVYGtVD=k-no""],""When"":""2025-9-5""},{""Name"":""Tori Hud"",""ProfilePicture"":""https://lh3.googleusercontent.com/a/ACg8ocI9TnoQRNGhbkj08c-nMwRR8N4e9bqAXJEs2DyZyEJeUaIm0w=s120-c-rp-mo-br100"",""Rating"":1,""Description"":""I have never left a review before but I just cannot believe the poor customer service I received here. I wanted to grab something quick for dinner so I thought I would give them a try. First, I could not place my order online despite it being 2 hours before they closed. Though, I decided to go place an order at the restaurant since it would be on my way home.  I went in and no one greeted me, I had to ask where I could place an order which a server directed me to the bar. I place an order with the bartender who seemed nice and had a drink while I waited to my food was ready. Once I was ready to leave, the bartender took my card \u0026 swiped it without providing me with my bill. He then handed me my card back with a receipt. I looked at the receipt, and I noticed the price did not match what I had calculated so I asked him for my itemized receipt. The price was about $10 over what I had expected to pay. I will acknowledge that I  did not look at a food menu when I was there because I already knew what I wanted after attempting to place my order online. Though, I did look at the drink menu which I pointed to what drink I wanted when I placed my order with the bartender. The drink was supposed to be $10 but my receipt reflected that it was $15. The tacos online were $3 each but my receipt stated that it was $13.50 total which 3 tacos would be $9.  I brought it to the bartender’s attention and he said they haven’t updated their menus. I was not satisfied with that response because I have NEVER been here before so why as a customer would I assume that your price is different than what is reflected on the menu. He went to grab I guess you can call the shift lead Gabby, who he says is close with the manager. There was a language barrier as she only spoke Spanish and though he translated for her, her body language was completely rude and nasty. She refused to hear what I was saying and to be clear, if these prices were on the menu,I have absolutely no problem paying it. I usually never complain at restaurants so this interaction caught me off guard. Lol So she printed out a receipt that reflected the cost of one taco which is apparently $4.50 each which is different from the $3 price online. Which fine, I let that go because I did not look at a food menu while I was there so if they want to say that’s the online price, okay that’s fine. But the drink menu which are at the table when you come in shows that the drink is $10 and as mentioned I pointed to the bartender which he never said was inaccurate. I would’ve even paid the $15 for the drink if I was spoken to kindly but Gabby was so disrespectful in her communication, I was not having it. I was respectful in my questioning so I was confused, I’m not one to argue over $5. It’s the principal that your prices on your menu is one thing but you are charging me something else \u0026 you are refusing to honor it or listen to me when I’m bringing it to your awareness. That’s crazy! I was server for years so I understand how things work, I would never be disrespectful to staff. There wasn’t a manager there but I will be going to back tomorrow to express my frustration. As a FIRST time customer, this is a horrible experience and I would never return.  As the reviews reflect, the food is mediocre. It’s plenty of spots in Laurel that have better customer service \u0026 food. This was completely disappointing. Will management rectify the situation? Probably not because as the bartender stated, she’s close with them. You just lost a customer for something that can be easily resolved if your staff cared. Several reviews have complained about the poor service, so you would think changes would be made. These be the same places that be confused when they lose business. If you want to increase your prices that’s your decision but don’t have menus out that reflect something different and expect your customers to just accept it ESPECIALLY without informing them of said changes before they order. It’s completely misleading and downright manipulative and demonstrates bad business practices."",""Images"":null,""When"":""""},{""Name"":""Tara Lawson"",""ProfilePicture"":""https://lh3.googleusercontent.com/a-/ALV-UjUXUaMnzt_bLiGHrOVrHKcq4yzEFbrcx8aBbiez19SNlxcCzxDe=s120-c-rp-mo-ba3-br100"",""Rating"":2,""Description"":""The enchiladas jefe was not of high quality nor was it good. I ate it because I had waited 35 minutes to get it and was super hungry.  The margarita was ok. The waiter was really super busy and didn’t have much time to even take my order.  I had to go to the hostess stand to get silverware and napkins. there were many employees just milling around without direction, and they should’ve been helping the overburdened waiter.  I will not come back."",""Images"":null,""When"":""""},{""Name"":""Ash"",""ProfilePicture"":""https://lh3.googleusercontent.com/a-/ALV-UjXkx0H_03TwKIbNWuZG_aRjADni2rAHFdlBekojqktdvHUUiFsj=s120-c-rp-mo-ba3-br100"",""Rating"":5,""Description"":""2nd time here and loved both experiences. It was my birthday and they gave me a free dessert and sang me happy birthday. Highly recommend and my server Andres was very professional and sweet"",""Images"":[""https://lh3.googleusercontent.com/grass-cs/ANxoTn25h5h-nIzEBg6yw98b1Cn4jL2GInud1r14IEZcK085bNejH-eSsg2F2r0yFf9bGC5nSxJFChffDhsIg2hO8bkQVjlOCrLga_L9AGg2IEXuY4gbLdJR7BDmPs7-XheWT3G34VVa1tZVokV_=k-no"",""https://lh3.googleusercontent.com/grass-cs/ANxoTn3pcfXkj8AhhzLQ4qR03puqh4mrqTIM3p2cx5AsmS7bGcWu4DUxziUhM0SvtgnJibSEP_jofCSCnZm9O2mVPyas7OXaczJrjRcYruWnHaBaDG4e7MZ1HaivBRFwk4JfMLV1rq17-aTZ65o9=k-no""],""When"":""2025-6-25""},{""Name"":""Ivan Funes"",""ProfilePicture"":""https://lh3.googleusercontent.com/a-/ALV-UjX-VngVJWRtggroM9CfyCSSyNctbcWgvhTUfKks5cfh_kOsIXP1ow=s1